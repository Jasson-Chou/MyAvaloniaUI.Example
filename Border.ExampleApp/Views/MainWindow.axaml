<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Border.ExampleApp.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
        x:Class="Border.ExampleApp.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="Border.ExampleApp"
        Classes.dark="{Binding #DarkThemeRadioButton.IsChecked}">

    <Design.DataContext>
        <!-- This only sets the DataContext for the previewer in an IDE,
             to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs) -->
        <vm:MainViewModel />
    </Design.DataContext>
    <Window.Styles>
        <Style Selector="Window.dark">
          <Setter Property="RequestedThemeVariant" Value="Dark"/>
        </Style>
        <Style Selector="Window:not(.dark)">
          <Setter Property="RequestedThemeVariant" Value="Light"/>
        </Style>
        <Style Selector="TextBlock.primary">
            <Setter Property="Width" Value="120"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,5,0"/>
        </Style>
        <Style Selector="TextBox.primary">
            <Setter Property="MinWidth" Value="150"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,5,0,0"/>
        </Style>
    </Window.Styles>

    <Grid ColumnDefinitions="*, auto" RowDefinitions="auto, auto, *">
        
        <Border
            Grid.Column="0"
            Grid.Row="0"
            VerticalAlignment="Center"
            HorizontalAlignment="Center"
            Margin="{Binding #BorderMarginTextBox.Text, Converter={StaticResource StringToThicknessConverter}}"
            Padding="{Binding #BorderPaddingTextBox.Text, Converter={StaticResource StringToThicknessConverter}}"
            BorderThickness="{Binding #BorderThicknessNumericUpDown.Value, Converter={StaticResource DecimalToThicknessConverter}}"
            BorderBrush="{Binding #BorderColorPicker.Color, Converter={StaticResource ColorToBrushConverter}}"
            Background="{Binding #BorderBackgroundColorPicker.Color, Converter={StaticResource ColorToBrushConverter}}"
            CornerRadius="{Binding #CornerRadiusTextBox.Text, Converter={StaticResource StringToCornerRadiusConverter}}"
            BoxShadow="{Binding #BoxShadowTextBox.Text, Converter={StaticResource StringToBoxShadowsConverter}}"
        >
            <!--
            BoxShadow rules:
            - BoxShadow="offsetX offsetY blurRadius spreadRadius color"
        
            -->

            <TextBox Text="{Binding BorderSetting.Name}"
                     Foreground="{Binding #NameColorPicker.Color, Converter={StaticResource ColorToBrushConverter}}"
                     BorderThickness="0"
                     Background="Transparent"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center" />
        </Border>

        <ScrollViewer Grid.Column="1" Grid.Row="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
            <StackPanel>

            <TextBlock Text="Border Settings" FontSize="18" FontWeight="Bold" Margin="0,0,0,10" />
            <StackPanel Orientation="Horizontal">
                <StackPanel.Styles>
                    <Style Selector="RadioButton">
                        <Setter Property="VerticalAlignment" Value="Center"/>
                        <Setter Property="Margin" Value="5 0"/>
                    </Style>
                </StackPanel.Styles>
                <TextBlock Text="Theme Variant:" Classes="primary" />
                <RadioButton x:Name="LightThemeRadioButton" Content="Light" GroupName="ThemeVariant" IsChecked="True"/>
                <RadioButton x:Name="DarkThemeRadioButton" Content="Dark" GroupName="ThemeVariant" />
            </StackPanel>

            <StackPanel Orientation="Horizontal">
                <TextBlock Classes="primary" Text="Name Text Color:"/>
                <ColorPicker x:Name="NameColorPicker"
                    Color="{Binding BorderSetting.NameTextColor}"
                    IsAlphaEnabled="True"
                    IsColorSpectrumVisible="True"
                    IsColorPaletteVisible="True"
                    IsColorComponentsVisible="True"
                    IsColorPreviewVisible="True"
                    IsColorModelVisible="True" />
                <SelectableTextBlock Text="{Binding #NameColorPicker.Color}" 
                                     Margin="5 0"
                                     VerticalAlignment="Center"
                                     FontFamily="Consolas" TextAlignment="Center"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                <TextBlock Classes="primary" Text="Margin:"/>
                <TextBox x:Name="BorderMarginTextBox" Classes="primary" Text="{Binding BorderSetting.Margin}"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                <TextBlock Classes="primary" Text="Padding:"/>
                <TextBox x:Name="BorderPaddingTextBox" Classes="primary" Text="{Binding BorderSetting.Padding}" />
            </StackPanel>
            
            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                <TextBlock Classes="primary" Text="Border Thickness:"/>
                <NumericUpDown x:Name="BorderThicknessNumericUpDown" 
                               Increment="0.1" FormatString="F1"
                               Minimum="0" Maximum="20" Value="{Binding BorderSetting.Thickness}"  AllowSpin="True" MinWidth="150" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0, 0, 0, 5">
                <TextBlock Classes="primary" Text="Corner Radius:"/>
                <TextBox x:Name="CornerRadiusTextBox" Classes="primary" Text="{Binding BorderSetting.CornerRadius}" />
            </StackPanel>

            <StackPanel Orientation="Horizontal">
                <TextBlock Classes="primary" Text="Border Color:"/>
                <ColorPicker x:Name="BorderColorPicker"
                    Color="{Binding BorderSetting.BorderColor}"
                    IsAlphaEnabled="True"
                    IsColorSpectrumVisible="True"
                    IsColorPaletteVisible="True"
                    IsColorComponentsVisible="True"
                    IsColorPreviewVisible="True"
                    IsColorModelVisible="True" />
                <SelectableTextBlock Text="{Binding #BorderColorPicker.Color}" 
                                     Margin="5 0"
                                     VerticalAlignment="Center"
                                     FontFamily="Consolas" TextAlignment="Center"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal">
                <TextBlock Classes="primary" Text="Background Color:"/>
                <ColorPicker x:Name="BorderBackgroundColorPicker"
                    Color="{Binding BorderSetting.BackgroundColor}"
                    IsAlphaEnabled="True"
                    IsColorSpectrumVisible="True"
                    IsColorPaletteVisible="True"
                    IsColorComponentsVisible="True"
                    IsColorPreviewVisible="True"
                    IsColorModelVisible="True" />
                <SelectableTextBlock Text="{Binding #BorderBackgroundColorPicker.Color}" 
                                     Margin="5 0"
                                     VerticalAlignment="Center"
                                     FontFamily="Consolas" TextAlignment="Center"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <TextBlock Classes="primary" Text="Box Shadow:"/>
                <TextBox x:Name="BoxShadowTextBox" Classes="primary" Text="{Binding BorderSetting.BoxShadow}" />
            </StackPanel>

            

            <StackPanel Orientation="Horizontal">
                <Button Content="Save" Command="{Binding SaveBorderSettingCommand}"/>
                <Button Content="Load" Command="{Binding LoadBorderSettingCommand}"/>
                <Button Content="Gen Code(.axaml)" Command="{Binding GenCodeAxamlCommand}"/>
            </StackPanel>

        </StackPanel>
        </ScrollViewer>
        <!--Border Settings-->
        
        <TextBlock Grid.Column="0" Grid.Row="1" Text="Saved Border Settings" FontSize="18" FontWeight="Bold" Margin="0,10,0,5" />
        <ListBox Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="2"
                 Margin="5 0"
                 
                SelectionMode="Single"
                ScrollViewer.VerticalScrollBarVisibility="Auto"
                ItemsSource="{Binding BorderSettings}"
                SelectedItem="{Binding SelectedBorderSetting}">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                      <WrapPanel />
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                      <Border 
                              Margin="{Binding Margin, Converter={StaticResource StringToThicknessConverter}}"
                              Padding="{Binding Padding, Converter={StaticResource StringToThicknessConverter}}"
                              BorderThickness="{Binding Thickness, Converter={StaticResource DecimalToThicknessConverter}}" 
                              BorderBrush="{Binding BorderColor, Converter={StaticResource ColorToBrushConverter}}"
                              Background="{Binding BackgroundColor, Converter={StaticResource ColorToBrushConverter}}"
                              CornerRadius="{Binding CornerRadius, Converter={StaticResource StringToCornerRadiusConverter}}" 
                              BoxShadow="{Binding BoxShadow, Converter={StaticResource StringToBoxShadowsConverter}}"
                              >
                        <TextBlock Text="{Binding Name}"
                                   Foreground="{Binding NameTextColor, Converter={StaticResource ColorToBrushConverter}}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                      </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
    </Grid>

    
</Window>
